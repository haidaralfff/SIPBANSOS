{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/cmd/server/main.go",
      "routePrefix": "/_/backend"
    }
  },
  "build": {
    "env": {
      "CGO_ENABLED": "0",
      "GOOS": "linux",
      "GOARCH": "amd64"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/_/backend/api/:path*"
    }
  ]
}
